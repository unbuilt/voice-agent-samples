# Azure AI Search and Azure OpenAI endpoints
SEARCH_ENDPOINT=https://your-search-service.search.windows.net
AOAI_ENDPOINT=https://your-foundry-resource.openai.azure.com

# Keyless mode only: use managed identity / Entra ID with DefaultAzureCredential.

# Embedding model/deployment for integrated vectorization
AOAI_EMBEDDING_MODEL=text-embedding-3-large
AOAI_EMBEDDING_DEPLOYMENT=text-embedding-3-large
AOAI_EMBEDDING_DIMENSIONS=3072

# Azure OpenAI model/deployment for knowledge base answer synthesis
AOAI_GPT_MODEL=gpt-4-mini
AOAI_GPT_DEPLOYMENT=gpt-4-mini

# Resource names to create/update
INDEX_NAME=foundry-iq-pdf-index
KNOWLEDGE_SOURCE_NAME=foundry-iq-knowledge-source
KNOWLEDGE_BASE_NAME=foundry-iq-knowledge-base
DATA_SOURCE_NAME=foundry-iq-pdf-index-blob-datasource
SKILLSET_NAME=foundry-iq-pdf-index-skillset
INDEXER_NAME=foundry-iq-pdf-index-blob-indexer

# Blob data source for PDF ingestion
# Storage resource ID used by Azure AI Search data source (no connection keys)
STORAGE_RESOURCE_ID=/subscriptions/<sub-id>/resourceGroups/<rg>/providers/Microsoft.Storage/storageAccounts/<storage-account>
BLOB_CONTAINER_NAME=your-pdf-container
# Optional virtual folder inside container
BLOB_VIRTUAL_FOLDER=

# Text Split chunking options
CHUNK_SIZE=2000
CHUNK_OVERLAP=500
